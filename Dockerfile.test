FROM ubuntu:22.04

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        make \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work

ENTRYPOINT ["/bin/sh", "-c", "if [ -n \"$1\" ]; then make -f tests.mk test \"$1\"; else make -f tests.mk test; fi", "--"]
