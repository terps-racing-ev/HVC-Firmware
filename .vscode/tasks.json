{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build App A+B",
      "type": "shell",
      "command": "make",
      "args": [
        "-f",
        "dual_build.mk"
      ],
      "options": {
        "cwd": "${workspaceRoot}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build + Push A/B Binaries",
      "type": "shell",
      "command": "make -f dual_build.mk && scp build/bank_a/debug/HVC_a.bin build/bank_b/debug/HVC_b.bin ali@zfpi.local:/home/ali/hvcfirmware",
      "options": {
        "cwd": "${workspaceRoot}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Build STM",
      "type": "process",
      "command": "${command:stm32-for-vscode.build}",
      "options": {
        "cwd": "${workspaceRoot}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build Clean STM",
      "type": "process",
      "command": "${command:stm32-for-vscode.cleanBuild}",
      "options": {
        "cwd": "${workspaceRoot}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Flash STM",
      "type": "process",
      "command": "${command:stm32-for-vscode.flash}",
      "options": {
        "cwd": "${workspaceRoot}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
